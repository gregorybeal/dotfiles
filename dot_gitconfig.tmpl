# ~/.gitconfig — managed by chezmoi
[user]
    name  = {{ .gitName }}
    email = {{ .gitEmail }}
{{- if .gitSigningKey }}
    signingkey = {{ .gitSigningKey }}
{{- end }}

[init]
    defaultBranch = main

[pull]
    rebase = false

[push]
    default = simple
    autoSetupRemote = true

[core]
    editor = code --wait
    autocrlf = input

[color]
    ui = auto

[alias]
    co       = checkout
    br       = branch
    ci       = commit
    st       = status
    last     = log -1 HEAD
    unstage  = reset HEAD --
    visual   = log --oneline --graph --decorate --all
    amend    = commit --amend --no-edit
    undo     = reset --soft HEAD~1

[diff]
    colorMoved = default

[fetch]
    prune = true

# --- HTTPS credential management via gh CLI ---
{{- if eq .chezmoi.os "darwin" }}
[credential "https://github.com"]
    helper =
    helper = !/opt/homebrew/bin/gh auth git-credential

[credential "https://gist.github.com"]
    helper =
    helper = !/opt/homebrew/bin/gh auth git-credential
{{- else }}
[credential "https://github.com"]
    helper =
    helper = !gh auth git-credential

[credential "https://gist.github.com"]
    helper =
    helper = !gh auth git-credential
{{- end }}

# --- Per-folder identity (multi-account) ---
# Create ~/.gitconfig-work and ~/.gitconfig-personal then uncomment:
#[includeIf "gitdir:~/code/work/"]
#    path = ~/.gitconfig-work
#[includeIf "gitdir:~/code/personal/"]
#    path = ~/.gitconfig-personal

# --- Machine-specific overrides (gitignored) ---
[include]
    path = ~/.gitconfig.local
