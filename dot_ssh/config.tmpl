{{ if eq .sshVariant "windows" -}}
# ~/.ssh/config — Windows
# GitHub auth handled by gh CLI over HTTPS.

Host *
    ServerAliveInterval 60
    ServerAliveCountMax 3

# Jump box
Host jumpbox
    HostName lassssgate01.traderjoes.com
    User gbeal

# Socks proxy
Host socks
    HostName lassssgate01.traderjoes.com
    User gbeal
    DynamicForward 1080
    RequestTTY no
    SessionType none

# Registers behind the jump box
Host 172.20.* 172.22.* 172.23.* 172.31.*
    User root
    ProxyJump jumpbox
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null
    LogLevel Error

# Individual hosts
Host 100.124.1.117
    HostName 100.124.1.117
    User gbeal

Host lasstrlinux01
    HostName lasstrlinux01
    User gbeal

# Personal hosts
Host fedora-vm
    HostName 100.114.72.45
    User greg

Host outpost.tail9579a2.ts.net
    User root
    HostName outpost.tail9579a2.ts.net

{{ else if eq .sshVariant "minimal" -}}
# ~/.ssh/config — minimal (no jump box / no registers)
# For Linux boxes that don't reach the corporate network.
# GitHub auth handled by gh CLI over HTTPS.

Host *
    ServerAliveInterval 60
    ServerAliveCountMax 3
    ControlMaster auto
    ControlPath ~/.ssh/sockets/%r@%h-%p
    ControlPersist 600

Host 172.20.* 172.22.* 172.23.* 172.31.*
    User root
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null
    LogLevel Error

# Per-machine overrides (gitignored)
Include ~/.ssh/config.local

{{ else -}}
# ~/.ssh/config — Mac, Linux, WSL
# GitHub auth handled by gh CLI over HTTPS — no GitHub SSH needed here.

# >>> gen_ssh_registers include >>>
Include conf.d/registers
# <<< gen_ssh_registers include <<<

Host *
    ServerAliveInterval 60
    ServerAliveCountMax 3
    ControlMaster auto
    ControlPath ~/.ssh/sockets/%r@%h-%p
    ControlPersist 600
{{ if eq .chezmoi.os "darwin" }}
