# ~/.gitconfig
# Fill in name/email below, OR use the includeIf blocks for per-folder identity.

[user]
     name = gregorybeal
     email = gbeal@gbeal.com
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIGgQFu5y45IMj8QpDzWE7/PTCZec36+IWBv50kX8gjuE

[init]
    defaultBranch = main

[pull]
    rebase = false

[push]
    default = simple
    autoSetupRemote = true

[core]
    editor = code --wait
    autocrlf = input

[color]
    ui = auto

[alias]
    co = checkout
    br = branch
    ci = commit
    st = status
    last = log -1 HEAD
    unstage = reset HEAD --
    visual = log --oneline --graph --decorate --all
    amend = commit --amend --no-edit
    undo = reset --soft HEAD~1

[diff]
    colorMoved = default

[fetch]
    prune = true

# --- HTTPS credential management ---
# gh CLI takes care of GitHub auth via its own credential helper.
# After 'gh auth login', git automatically uses gh's stored token for HTTPS.
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential

[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential

# --- Per-folder identity (multi-account) ---
# Uncomment after creating ~/.gitconfig-work and ~/.gitconfig-personal
#[includeIf "gitdir:~/code/work/"]
#    path = ~/.gitconfig-work
#[includeIf "gitdir:~/code/personal/"]
#    path = ~/.gitconfig-personal

# --- Machine-specific overrides (gitignored) ---
[include]
    path = ~/.gitconfig.local