# Deploy VS Code settings, keybindings, and snippets (Windows).
# Runs on every chezmoi apply.

$VscodeUser = "$env:APPDATA\Code\User"
$Src = "{{ .chezmoi.sourceDir }}\vscode"

if (-not (Test-Path $Src)) { exit 0 }
New-Item -ItemType Directory -Force -Path "$VscodeUser\snippets" | Out-Null

foreach ($f in @("settings.json", "keybindings.json")) {
    $path = Join-Path $Src $f
    if (Test-Path $path) { Copy-Item $path "$VscodeUser\$f" }
}

foreach ($snippet in Get-ChildItem "$Src\snippets\*.json" -ErrorAction SilentlyContinue) {
    Copy-Item $snippet.FullName "$VscodeUser\snippets\$($snippet.Name)"
}

# Windows Terminal
$WtConfig = "$env:LOCALAPPDATA\Packages\Microsoft.WindowsTerminal_8wekyb3d8bbwe\LocalState\settings.json"
$WtSrc = "{{ .chezmoi.sourceDir }}\windows-terminal\settings.json"
if ((Test-Path $WtSrc) -and (Test-Path (Split-Path $WtConfig -Parent))) {
    Copy-Item $WtSrc $WtConfig
}
