# One-time: copy reg-tool config.example to ~/.config/reg-tool/config if not present.
$ConfigDir = "$env:USERPROFILE\.config\reg-tool"
$Config = "$ConfigDir\config"
New-Item -ItemType Directory -Force -Path $ConfigDir | Out-Null
if (-not (Test-Path $Config)) {
    Copy-Item "{{ .chezmoi.sourceDir }}\reg-tool\config.example" $Config
    Write-Host "[reg-tool] Created $Config — edit it to set your jumpbox and SQLite paths."
}
