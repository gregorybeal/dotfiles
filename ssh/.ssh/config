# ~/.ssh/config — stowed from ~/dotfiles/ssh
# Mac, Linux, WSL. GitHub auth handled by gh CLI over HTTPS — no GitHub SSH needed here.
# On macOS, SSH_AUTH_SOCK is already pointed at the 1Password agent (see zsh/bash .zshenv),
# so no explicit IdentityAgent override is needed here.

# >>> gen_ssh_registers include >>>
Include conf.d/registers
# <<< gen_ssh_registers include <<<

Host *
    ServerAliveInterval 60
    ServerAliveCountMax 3
    ControlMaster auto
    ControlPath ~/.ssh/sockets/%r@%h-%p
    ControlPersist 600

# Jump box
Host jumpbox
    HostName lassssgate01.traderjoes.com
    User gbeal

# Socks proxy
Host socks
    HostName lassssgate01.traderjoes.com
    User gbeal
    DynamicForward 1080
    RequestTTY no
    SessionType none

# Registers behind the jump box
Host 172.20.* 172.22.* 172.23.* 172.31.*
    User root
    ProxyJump jumpbox
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null
    LogLevel Error

# Individual hosts
Host pochacco
    HostName 100.124.1.117
    User gbeal

Host lnx
    HostName lasstrlinux01
    User gbeal

# Personal hosts
Host fedora-vm
    HostName 100.114.72.45
    User greg

Host outpost
    User root
    HostName 100.114.127.126
    User greg

Host macmini
    HostName 100.118.20.30
    User greg

# Per-machine overrides (gitignored)
Include ~/.ssh/config.local
