{
    "uv inline script header (PEP 723)": {
        "prefix": "uvscript",
        "body": [
            "#!/usr/bin/env -S uv run --script",
            "# /// script",
            "# requires-python = \">=${1:3.10}\"",
            "# dependencies = [",
            "#     \"${2:requests}\",",
            "# ]",
            "# ///",
            "\"\"\"${3:Brief description of what this script does.}\"\"\"",
            "$0"
        ],
        "description": "uv self-contained script header with PEP 723 metadata"
    },
    "Python main + argparse": {
        "prefix": "main",
        "body": [
            "import argparse",
            "import sys",
            "",
            "",
            "def main() -> int:",
            "    ap = argparse.ArgumentParser(description=\"${1:Description}\")",
            "    ap.add_argument(\"${2:input}\", help=\"${3:Help text}\")",
            "    ap.add_argument(\"--${4:flag}\", action=\"store_true\", help=\"${5:Flag description}\")",
            "    args = ap.parse_args()",
            "",
            "    ${6:# main logic here}",
            "    return 0",
            "",
            "",
            "if __name__ == \"__main__\":",
            "    sys.exit(main())",
            "$0"
        ],
        "description": "Python script with main() and argparse"
    },
    "SSH command (paramiko/fabric pattern)": {
        "prefix": "sshcmd",
        "body": [
            "import subprocess",
            "",
            "def ssh_run(host: str, cmd: str, user: str = \"${1:posuser}\", jump: str = \"${2:jumpbox}\") -> tuple[int, str, str]:",
            "    \"\"\"Run a command on a remote host via SSH (with optional jump host).\"\"\"",
            "    ssh_args = [\"ssh\", \"-J\", jump, f\"{user}@{host}\", cmd]",
            "    result = subprocess.run(ssh_args, capture_output=True, text=True, timeout=${3:30})",
            "    return result.returncode, result.stdout, result.stderr",
            "$0"
        ],
        "description": "SSH command helper (matches your reg-tool style)"
    },
    "SQLite query function": {
        "prefix": "sqlitequery",
        "body": [
            "import sqlite3",
            "from pathlib import Path",
            "",
            "def query_db(db_path: Path, sql: str, params: tuple = ()) -> list[sqlite3.Row]:",
            "    \"\"\"Run a parameterized query and return rows.\"\"\"",
            "    conn = sqlite3.connect(db_path)",
            "    conn.row_factory = sqlite3.Row",
            "    try:",
            "        return conn.execute(sql, params).fetchall()",
            "    finally:",
            "        conn.close()",
            "$0"
        ],
        "description": "SQLite query helper"
    },
    "Logging setup": {
        "prefix": "logging",
        "body": [
            "import logging",
            "",
            "logging.basicConfig(",
            "    level=logging.${1:INFO},",
            "    format=\"%(asctime)s [%(levelname)s] %(name)s: %(message)s\",",
            "    datefmt=\"%H:%M:%S\",",
            ")",
            "log = logging.getLogger(__name__)",
            "$0"
        ],
        "description": "Standard logging setup"
    }
}
