{
    "Ansible playbook scaffold": {
        "prefix": "playbook",
        "body": [
            "---",
            "- name: ${1:Description}",
            "  hosts: ${2:all}",
            "  gather_facts: ${3:false}",
            "  become: ${4:false}",
            "  vars:",
            "    ${5:key}: ${6:value}",
            "  tasks:",
            "    - name: ${7:Task name}",
            "      ${8:ansible.builtin.debug}:",
            "        msg: \"${9:Hello}\"",
            "$0"
        ],
        "description": "New Ansible playbook scaffold"
    },
    "Ansible task": {
        "prefix": "task",
        "body": [
            "- name: ${1:Task name}",
            "  ${2:ansible.builtin.command}: ${3:cmd}",
            "  register: ${4:result}",
            "  changed_when: ${5:false}",
            "$0"
        ],
        "description": "Ansible task with register"
    },
    "Ansible block with rescue": {
        "prefix": "block",
        "body": [
            "- name: ${1:Block description}",
            "  block:",
            "    - name: ${2:Try this}",
            "      ${3:ansible.builtin.command}: ${4:cmd}",
            "  rescue:",
            "    - name: ${5:On failure}",
            "      ansible.builtin.debug:",
            "        msg: \"Failed: {{ ansible_failed_result }}\"",
            "  always:",
            "    - name: ${6:Always run}",
            "      ansible.builtin.debug:",
            "        msg: \"Done\"",
            "$0"
        ],
        "description": "Ansible block/rescue/always pattern"
    },
    "Ansible role include": {
        "prefix": "include_role",
        "body": [
            "- name: Include ${1:role_name}",
            "  ansible.builtin.include_role:",
            "    name: ${1:role_name}",
            "  vars:",
            "    ${2:var}: ${3:value}",
            "$0"
        ],
        "description": "Include an Ansible role"
    },
    "Authorized key task": {
        "prefix": "authorized_key",
        "body": [
            "- name: Deploy SSH key for ${1:user}",
            "  ansible.posix.authorized_key:",
            "    user: ${1:user}",
            "    state: present",
            "    key: \"{{ lookup('file', '${2:~/.ssh/id_ed25519.pub}') }}\"",
            "$0"
        ],
        "description": "Deploy SSH key (the reg fleet pattern)"
    }
}
